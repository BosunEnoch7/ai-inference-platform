# Application
APP_NAME=AI Inference Platform
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Inference provider: mock or openai.
LLM_PROVIDER=mock
INFERENCE_TIMEOUT_SECONDS=30

# Optional inference authentication. Inject the key through a secret manager in production.
API_AUTH_ENABLED=false
INFERENCE_API_KEY=

# Required only when LLM_PROVIDER=openai. Never commit a real value.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_RETRIES=2

# Local Grafana administrator. Set a strong local value before Docker Compose starts.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
